<?xml version="1.0" encoding="utf-8" ?>
<odoo>
    <record model="ir.ui.view" id="product_template_form_view_procurement_button">
        <field name="name">product.template.pack.form</field>
        <field name="model">product.template</field>
        <field
            name="inherit_id"
            ref="stock.product_template_form_view_procurement_button"
        />
        <field name="arch" type="xml">
            <button name="action_open_quants" position="attributes">
                <attribute
                    name="attrs"
                >{'invisible':[('pack_ok', '=', False),('type', '!=', 'product')]}</attribute>
            </button>
            <button name="action_product_tmpl_forecast_report" position="attributes">
                <attribute
                    name="attrs"
                >{'invisible':[('pack_ok', '=', False),('type', '!=', 'product')]}</attribute>
            </button>
        </field>
    </record>
    <record model="ir.ui.view" id="product_template_kanban_stock_view">
        <field name="name">product.template.pack.kanban</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="stock.product_template_kanban_stock_view" />
        <field name="arch" type="xml">
            <xpath expr="//ul//field[@name='qty_available']//.." position="attributes">
                <attribute
                    name="t-if"
                >record.pack_ok == True or record.type.raw_value == 'product'</attribute>
            </xpath>
        </field>
    </record>
    <record model="ir.ui.view" id="view_stock_product_template_tree">
        <field name="name">product.template.pack.tree</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="stock.view_stock_product_template_tree" />
        <field name="arch" type="xml">
            <field name="qty_available" position="after">
                <field name="pack_ok" invisible="1" />
            </field>
            <field name="qty_available" position="attributes">
                <attribute
                    name="attrs"
                >{'invisible':[('pack_ok', '=', False),('type', '!=', 'product')]}</attribute>
            </field>
            <field name="virtual_available" position="attributes">
                <attribute
                    name="attrs"
                >{'invisible':[('pack_ok', '=', False),('type', '!=', 'product')]}</attribute>
            </field>
        </field>
    </record>
</odoo>
